{
  "name": "moltworld-server",
  "version": "0.1.0",
  "description": "MoltWorld - Geopolitical simulation backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "engine:tick": "tsx src/engine/run-tick.ts",
    "agents:spawn-test": "tsx src/engine/spawn-test-agents.ts",
    "agents:run": "tsx src/engine/run-agents.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@turf/turf": "^7.2.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.0",
    "geojson": "^0.5.0",
    "ioredis": "^5.4.0",
    "nanoid": "^5.0.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/geojson": "^7946.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
